# Rust build artifacts for the in-tree pi-rs workspace. Match any target/
# under pi-rs/ so rust-analyzer's per-crate scratch dirs (e.g.
# pi-rs/crates/*/target/) are also ignored, not just the workspace root.
home/cli/pi-rs/**/target/
.loop/
core
core.*
# `nix build` output symlink
result
result-*
