node_modules/
package.json
package-lock.json
# But DO track pi extension package manifests — they're authored.
!home/cli/pi-extensions/*/package.json
!home/cli/pi-extensions/*/package-lock.json
# Rust build artifacts for the in-tree pi-rs workspace. Match any target/
# under pi-rs/ so rust-analyzer's per-crate scratch dirs (e.g.
# pi-rs/crates/*/target/) are also ignored, not just the workspace root.
home/cli/pi-rs/**/target/
# Ephemeral pi-rs benchmark trees (each .bench-* dir holds a cargo target/)
home/cli/pi-rs/.bench-*/
.loop/
# Transient Claude Code scheduled-task lock (per-session runtime state)
.claude/scheduled_tasks.lock
core
core.*
# `nix build` output symlink
result
result-*
